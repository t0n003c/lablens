# Local development template. For NAS or Dockge image deployment, use
# .env.nas.example instead.

# App
APP_URL="http://localhost:3000"
# Generate with: openssl rand -hex 32
SESSION_SECRET="replace-with-32-plus-random-characters"
DEPLOYMENT_VERSION="local"
NODE_ENV="development"

# Database
# Local source development can use this localhost URL. Docker Compose overrides
# DATABASE_URL inside the app container so the app reaches Postgres by service name.
DATABASE_URL="postgresql://lablens:lablens_dev_password@localhost:5433/lablens?schema=public"
POSTGRES_USER="lablens"
# For NAS/image deployments, replace this with a strong generated password before
# the first database start and keep it unchanged after the Postgres volume exists.
POSTGRES_PASSWORD="lablens_dev_password"
POSTGRES_DB="lablens"

# Uploads and retention
MAX_UPLOAD_MB="12"
STORE_RAW_PDFS="false"
UPLOAD_DIR="/app/data/uploads"

# Optional Cloudflare Turnstile
TURNSTILE_ENABLED="false"
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# AI provider: mock, openai-compatible, or local
AI_PROVIDER="mock"
AI_MODEL="local-lab-summary"
AI_BASE_URL=""
AI_API_KEY=""

# Reserved for future app-level encryption migrations. It does not encrypt saved
# lab values in the current version, but production installs should set and keep
# one stable random key so future migrations can use the same secret.
# Generate with: openssl rand -hex 32
DATA_ENCRYPTION_KEY=""
