# Copy this file to .env in your NAS/Dockge stack folder, then fill in secrets
# before the first database start.

# App
APP_URL="http://192.168.1.50:3449"
# Generate with: openssl rand -hex 32
SESSION_SECRET=""
DEPLOYMENT_VERSION="1.0.0"
NODE_ENV="production"

# Database
# Keep POSTGRES_PASSWORD unchanged after the Postgres volume exists.
POSTGRES_USER="lablens"
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=""
POSTGRES_DB="lablens"

# Uploads and retention
MAX_UPLOAD_MB="20"
STORE_RAW_PDFS="false"
UPLOAD_DIR="/app/data/uploads"

# Optional Cloudflare Turnstile
TURNSTILE_ENABLED="false"
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# AI provider: mock, openai-compatible, or local
AI_PROVIDER="mock"
AI_MODEL="local-lab-summary"
AI_BASE_URL=""
AI_API_KEY=""

# Reserved for future app-level encryption migrations. It does not encrypt saved
# lab values in the current version, but production installs should set and keep
# one stable random key so future migrations can use the same secret.
# Generate with: openssl rand -hex 32
DATA_ENCRYPTION_KEY=""
